# EditorConfig — règles cross-IDE pour cohérence de formatage.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,ts,jsx,tsx,svelte,json,jsonc,html,css,scss,yml,yaml,md}]
indent_size = 2

[*.{rs,toml}]
indent_size = 4

[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4

# Préserver le formatage existant des fichiers makefile-like
[Makefile]
indent_style = tab
